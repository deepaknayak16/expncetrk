<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
<!-- Exclude the encrypted DB — key won't survive restore -->
<exclude domain="database" path="expense_tracker.db" />
<!-- Exclude preferences that hold keystore references -->
<exclude domain="sharedpref" path="com.example.expncetracker_preferences" />
<!-- Allow only user-exported backup JSON -->
<include domain="file" path="expense_tracker_backup.json" />
</full-backup-content>